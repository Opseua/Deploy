{
  "manifest_version": 2,
  "name": "# BOT",
  "version": "1.0.0",
  "icons": {
    "16": "./src/media/iconBOT.png",
    "32": "./src/media/iconBOT.png",
    "48": "./src/media/iconBOT.png",
    "128": "./src/media/iconBOT.png"
  },
  "permissions": [
    "<all_urls>",
    "background",
    "activeTab",
    "proxy",
    "identity",
    "identity.email",
    "downloads",
    "downloads.shelf",
    "unlimitedStorage",
    "notifications",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus",
    "alarms",
    "cookies",
    "declarativeContent",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "desktopCapture",
    "management",
    "webNavigation",
    "nativeMessaging",
    "pageCapture",
    "storage",
    "system.memory",
    "tabCapture",
    "tabs",
    "webRequest",
    "webRequestBlocking"
  ],
  "browser_action": {
    "n": "NÃO REMOVER 'browser_action'!!!"
  },
  "background": {
    "scripts": [
      "./src/scripts/background.js"
    ],
    "persistent": true
  },
  "commands": {
    "shortcut_1": {
      "description": "shortcut_1"
    },
    "shortcut_2": {
      "description": "shortcut_2"
    }
  },
  "OLD_incognito": "split",
  "x": "",
  "OLD_content_security_policy": "object-src 'self'; http://127.0.0.1:* http://localhost:* http://* https://* ws://*:* wss://*:* chrome://*; script-src 'self' 'unsafe-eval' blob: filesystem: https://cdn.jsdelivr.net https://esm.sh https://unpkg.com https://cdnjs.cloudflare.com https://cdn.skypack.dev",
  "x1": "",
  "content_security_policy": "object-src 'self'; script-src 'self' 'unsafe-eval' blob: filesystem: https://cdn.jsdelivr.net https://esm.sh https://unpkg.com https://cdnjs.cloudflare.com https://cdn.skypack.dev",
  "x2": "",
  "description": ""
}