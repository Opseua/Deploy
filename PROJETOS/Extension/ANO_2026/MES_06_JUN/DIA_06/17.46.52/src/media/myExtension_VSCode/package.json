{
  "name": "myExtension",
  "displayName": "z_My Extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "main": "extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode_extension.replaceAspas",
        "title": "Trocar aspas simples por duplas",
        "icon": "$(replace)"
      },
      {
        "command": "vscode_extension.replaceAcentos",
        "title": "Remover acentos",
        "icon": "$(clear-all)"
      },
      {
        "command": "vscode_extension.reduceBreakLines",
        "title": "Compactar quebras de linha",
        "icon": "$(fold)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vscode_extension.replaceAspas",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "command": "vscode_extension.replaceAcentos",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "command": "vscode_extension.reduceBreakLines",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ]
    }
  }
}